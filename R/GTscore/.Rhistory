mutate(year = case_when(str_detect(date,"2020") ~ 2020,
str_detect(date,"2021") ~ 2021,
str_detect(date,"2022") ~ 2022,
str_detect(date,"2023") ~ 2023),
river_name_clean = str_replace_all(river_name," ","")) %>%
mutate(collection = paste(river_name_clean,year,sep = "_"))
sampleMetaData %<>% left_join(data,by = c("FISHES_ID"="FISHES_ID_2"))
sampleMetaData %<>% distinct()
sampleMetaData_final <- data.frame(sample_type=sampleMetaData$stock,repunit=NA,collection=sampleMetaData$collection,indiv=sampleMetaData$FISHES_ID)
sampleMetaData_final %>% group_by(sample_type) %>% dplyr::count()
sampleMetaData_final %<>% mutate(sample_type = gsub("mixed","Mixed",sample_type))
sampleMetaData_final %<>% mutate(sample_type = case_when(is.na(sample_type) & str_detect("m",indiv) ~ "Mixed",
is.na(sample_type) & str_detect("s",indiv) ~ "Source",
T ~ sample_type))
polyGenResults_singleSNP <- read.table("GTscore_results/polyGenResults_singleSNP.txt",header=T)
# Rename the columns, matching either coar or cocl, and allowing for underscores
colnames(polyGenResults_singleSNP) <- gsub("\\.", "_", colnames(polyGenResults_singleSNP))
exportRubias(polyGenResults_singleSNP,
singleSNP_locusTable,
sampleMetaData_final,
sampleBlacklist=contaminatedSample,
locusBlacklist=poorQualitySNPs,
filename="GTscore_results/polyGenResults_singleSNP_rubias.txt")
source_mixed_id <- read.table("GTscore_results/polyGenResults_singleSNP_rubias.txt",header = T)
source_id <- source_mixed_id %>% filter(sample_type == "Source") %>% pull(indiv)
exportGenepop(polyGenResults_singleSNP,
singleSNP_locusTable,
locusBlacklist=poorQualitySNPs,
sampleWhitelist = source_id,
sampleBlacklist = contaminatedSample,
filename="GTscore_results/polyGenResults_singleSNP_genepop_source.txt")
exportRubias(polyGenResults_singleSNP,
singleSNP_locusTable,
sampleMetaData_final,
sampleBlacklist=contaminatedSample,
locusBlacklist=poorQualitySNPs,
filename="GTscore_results/polyGenResults_singleSNP_rubias.txt")
exportRubias(polyGenResults_singleSNP,
singleSNP_locusTable,
sampleMetaData_final,
